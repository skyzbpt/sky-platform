{
  "name": "sky-platform",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "SKY_KV",
      "id": "82ba4ca48a8a4e96aa4953f5a530edde"
    }
  ],
  "observability": {
    "enabled": true
  }
}
